{
  "name": "screenshot-tool",
  "version": "1.0.0",
  "productName": "RedCap",
  "description": "macOS screenshot annotation tool",
  "main": "src/main.js",
  "scripts": {
    "build": "vite build",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.redcap.screenshot-tool",
    "productName": "RedCap",
    "asar": true,
    "files": [
      "src/main.js",
      "src/preload-overlay.js",
      "src/preload-annotation.js",
      "src/assets/**",
      "dist/overlay.html",
      "dist/annotation.html",
      "dist/assets/**"
    ],
    "directories": {
      "output": "dist/release",
      "buildResources": "assets"
    },
    "mac": {
      "icon": "assets/AppIcon.icns",
      "category": "public.app-category.productivity",
      "target": [{ "target": "dir", "arch": ["arm64"] }],
      "identity": null
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true
  }
}
